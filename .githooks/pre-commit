#!/bin/bash
# Pre-commit hook: run regression if pipeline Python code changed

PIPELINE_CHANGED=$(git diff --cached --name-only | grep -E '^src/.*\.py$|^src/player/.*\.py$' | head -1)

if [ -n "$PIPELINE_CHANGED" ]; then
    echo "Pipeline code changed — running regression..."
    source src/env.sh 2>/dev/null
    RESULT=$(python3 src/player/regression_test.py 2>&1 | tail -1)

    if echo "$RESULT" | grep -q "0 failed"; then
        echo "Regression OK: $RESULT"
    else
        echo "REGRESSION FAILED: $RESULT"
        echo "Fix the regression before committing."
        exit 1
    fi
fi
